   "cell_type": "markdown",
   "id": "9525bb54",
   "metadata": {},
   "source": [
    "# Verapamil Adverse Reaction Analysis (FDA FAERS)\n",
    "\n",
    "This notebook retrieves and analyzes adverse drug reaction data for **verapamil** from the FDA FAERS database over the past 20 years.\n",
    "\n",
    
    "- Data reflects reported events, not confirmed causation.\n",
    "- Counts represent number of reports, not number of patients.\n",
  
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d365b415",
   "metadata": {},
   "outputs": [],
   "source": [
    "import requests\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "from datetime import datetime, timedelta"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "09cc3edb",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define 20-year time window\n",
    "end_date = datetime.today()\n",
    "start_date = end_date - timedelta(days=365 * 20)\n",
    "\n",
    "start_str = start_date.strftime(\"%Y%m%d\")\n",
    "end_str = end_date.strftime(\"%Y%m%d\")\n",
    "\n",
    "print(f\"Time window: {start_str} → {end_str}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7197faf0",
   "metadata": {},
   "outputs": [],
   "source": [
    "url = \"https://api.fda.gov/drug/event.json\"\n",
    "\n",
    "params = {\n",
    "    \"search\": (\n",
    "        f\"patient.drug.medicinalproduct:(verapamil OR calan OR isoptin) \"\n",
    "        f\"AND receivedate:[{start_str} TO {end_str}]\"\n",
    "    ),\n",
    "    \"count\": \"patient.reaction.reactionmeddrapt.exact\",\n",
    "    \"limit\": 10\n",
    "}\n",
    "\n",
    "response = requests.get(url, params=params)\n",
    "\n",
    "# Error handling\n",
    "if response.status_code != 200:\n",
    "    print(f\"Error: {response.status_code}\")\n",
    "    print(response.text)\n",
    "    raise SystemExit\n",
    "\n",
    "data = response.json()\n",
    "\n",
    "if \"results\" not in data:\n",
    "    print(\"No data returned from FDA API\")\n",
    "    print(data)\n",
    "    raise SystemExit"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bc7fd0c6",
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.DataFrame(data[\"results\"])\n",
    "\n",
    "df = df.rename(columns={\n",
    "    \"term\": \"reaction\",\n",
    "    \"count\": \"count\"\n",
    "})\n",
    "\n",
    "df[\"count\"] = pd.to_numeric(df[\"count\"])\n",
    "\n",
    "# Sort for plotting (ascending)\n",
    "df = df.sort_values(\"count\", ascending=True)\n",
    "\n",
    "df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "093a9540",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"=\"*60)\n",
    "print(\"VERAPAMIL ADVERSE REACTIONS (LAST 20 YEARS)\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "print(f\"\\nTotal reaction types shown: {len(df)}\")\n",
    "print(f\"Total reports (top reactions only): {df['count'].sum()}\")\n",
    "\n",
    "print(\"\\nTop Reported Reactions:\")\n",
    "print(\"-\"*60)\n",
    "\n",
    "df_desc = df.sort_values(\"count\", ascending=False)\n",
    "\n",
    "for _, row in df_desc.iterrows():\n",
    "    print(f\"{row['reaction']:<35} | {row['count']}\")\n",
    "\n",
    "print(\"\\nNOTE: Counts represent report frequency, not incidence or causation.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dbfca24c",
   "metadata": {},
   "outputs": [],
   "source": [
    "colors = plt.cm.viridis(np.linspace(0, 1, len(df)))\n",
    "\n",
    "plt.figure(figsize=(14, 7))\n",
    "plt.barh(df[\"reaction\"], df[\"count\"], color=colors)\n",
    "\n",
    "plt.title(\"Verapamil Adverse Reactions (Last 20 Years)\", fontsize=14)\n",
    "plt.xlabel(\"Number of Reports\")\n",
    "plt.ylabel(\"Reaction\")\n",
    "\n",
    "plt.grid(axis='x', linestyle='--', alpha=0.5)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
